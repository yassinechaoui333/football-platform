# ===========================================
# Football Analytics Platform - Environment
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# API-Football credentials
API_KEY=your_api_key_here
API_HOST=v3.football.api-sports.io

# Database credentials
DB_HOST=postgres
DB_PORT=5432
DB_NAME=football_db
DB_USER=football_user
DB_PASSWORD=change_me_to_a_strong_password

# Airflow
AIRFLOW_DB_NAME=airflow_db
AIRFLOW_FERNET_KEY=generate_with_python_-c_"from_cryptography.fernet_import_Fernet;_print(Fernet.generate_key().decode())"
AIRFLOW_ADMIN_PASSWORD=change_me

# pgAdmin
PGADMIN_EMAIL=admin@football.com
PGADMIN_PASSWORD=change_me

# Ollama (RAG system)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
